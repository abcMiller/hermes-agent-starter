# ============================================
# Provider Configuration
# ============================================
# Options: mock | openai-compatible | ollama
# Run `hermes-clone providers --detailed` for more examples

HERMES_PROVIDER=mock

# --------------------------------------------
# Mock Provider (for testing, no API key needed)
# --------------------------------------------
# HERMES_PROVIDER=mock

# --------------------------------------------
# DeepSeek (https://api.deepseek.com)
# --------------------------------------------
# HERMES_PROVIDER=openai-compatible
# HERMES_BASE_URL=https://api.deepseek.com
# HERMES_API_KEY=sk-xxx
# HERMES_MODEL=deepseek-chat

# --------------------------------------------
# OpenAI (https://api.openai.com)
# --------------------------------------------
# HERMES_PROVIDER=openai-compatible
# HERMES_BASE_URL=https://api.openai.com/v1
# HERMES_API_KEY=sk-xxx
# HERMES_MODEL=gpt-4o-mini

# --------------------------------------------
# OpenRouter (https://openrouter.ai)
# --------------------------------------------
# HERMES_PROVIDER=openai-compatible
# HERMES_BASE_URL=https://openrouter.ai/api/v1
# HERMES_API_KEY=sk-or-xxx
# HERMES_MODEL=anthropic/claude-3-haiku

# --------------------------------------------
# Kimi / Moonshot (https://api.moonshot.cn)
# --------------------------------------------
# HERMES_PROVIDER=openai-compatible
# HERMES_BASE_URL=https://api.moonshot.cn/v1
# HERMES_API_KEY=sk-xxx
# HERMES_MODEL=moonshot-v1-8k

# --------------------------------------------
# GLM / ChatGLM (https://open.bigmodel.cn)
# --------------------------------------------
# HERMES_PROVIDER=openai-compatible
# HERMES_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# HERMES_API_KEY=xxx
# HERMES_MODEL=glm-4

# --------------------------------------------
# Ollama (local models, requires ollama serve)
# --------------------------------------------
# HERMES_PROVIDER=ollama
# HERMES_BASE_URL=http://localhost:11434
# HERMES_MODEL=llama3:8b

# ============================================
# Runtime Paths
# ============================================
HERMES_DATA_DIR=./data
HERMES_WORKSPACE_DIR=./workspace

# ============================================
# Tool Safety
# ============================================
HERMES_ENABLE_SHELL=false
HERMES_SHELL_TIMEOUT_MS=15000
HERMES_MAX_ITERATIONS=8
HERMES_ALLOWED_SHELL_COMMANDS=pwd,ls,cat,echo,node,npm,pnpm,git

# ============================================
# Debug
# ============================================
# HERMES_DEBUG=true
